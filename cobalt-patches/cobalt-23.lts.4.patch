+
+void YtafLogCallback(const v8::FunctionCallbackInfo<v8::Value>& args) {
+  v8::Isolate* isolate = args.GetIsolate();
+  v8::Local<v8::Context> context = isolate->GetCurrentContext();
+  std::string message;
+  for (int i = 0; i < args.Length(); ++i) {
+    if (i > 0) {
+      message += " ";
+    }
+    v8::Local<v8::String> value_string;
+    if (args[i]->ToString(context).ToLocal(&value_string)) {
+      v8::String::Utf8Value value(isolate, value_string);
+      if (*value) {
+        message += *value;
+      }
+    }
+  }
+  YtafFileLog("[YTAF-JS-NATIVE] " + message);
+}
